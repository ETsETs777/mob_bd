<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#161B22"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_brand"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="EcoPulse"
            android:textColor="#58A6FF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_updated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#8B949E"
            android:textSize="10sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="#21262D"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:id="@+id/widget_slot1_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="USD/RUB"
                android:textColor="#8B949E"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/widget_slot1_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#F0F6FC"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_slot1_change"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#3FB950"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="#21262D"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:id="@+id/widget_slot2_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BTC"
                android:textColor="#8B949E"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/widget_slot2_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#F0F6FC"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_slot2_change"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#3FB950"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="#21262D"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:id="@+id/widget_slot3_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CBR"
                android:textColor="#8B949E"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/widget_slot3_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#F0F6FC"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_slot3_change"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#3FB950"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="#21262D"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:id="@+id/widget_slot4_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IMOEX"
                android:textColor="#8B949E"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/widget_slot4_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#F0F6FC"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_slot4_change"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#3FB950"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
